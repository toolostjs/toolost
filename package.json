{
  "name": "toolost",
  "version": "1.0.0",
  "description": "Community-baked JavaScript/TypeScript SDK for the Too Lost API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run lint"
  },
  "keywords": [
    "toolost",
    "toolost api",
    "music distribution",
    "sdk"
  ],
  "authors": [
    "ByJonas <www.byjonas.dev>",
    "TooLostJS Contributors <https://github.com/toolostjs/toolost/graphs/contributors>"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "homepage": "https://toolost.js.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toolostjs/toolost.git"
  },
  "bugs": {
    "url": "https://github.com/toolostjs/toolost/issues"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
